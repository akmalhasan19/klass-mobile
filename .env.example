# Rust Gateway Environment Variables
# Copy ke .env dan isi dengan values sebenarnya

# Server
HOST=0.0.0.0
PORT=8080
GRPC_PORT=50051

# Neon PostgreSQL (Backend)
DATABASE_URL=postgresql://username:password@ep-xxx.us-east-2.aws.neon.tech/klass_backend?sslmode=require

# Upstash Redis (Job Queue)
UPSTASH_REDIS_REST_URL=https://xxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=AXxx...

# Cloudflare R2 (File Storage)
R2_ENDPOINT=https://<ACCOUNT_ID>.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=your_access_key_id
R2_SECRET_ACCESS_KEY=your_secret_access_key
R2_BUCKET_NAME=klass-backend
R2_PUBLIC_URL=https://pub-xxx.r2.dev

# Media Gen HF Space (HTTP/2 + HMAC)
MEDIA_GEN_URL=https://your-media-gen.hf.space
MEDIA_GEN_HMAC_SECRET=your_hmac_secret_here

# LLM Providers
GEMINI_API_KEY=your_gemini_api_key
OPENAI_API_KEY=your_openai_api_key

# Laravel Sanctum Compatibility
SANCTUM_GUARD=web
SANCTUM_HASH_algo=sha256

# HMAC Service-to-Service
HMAC_SECRET=your_hmac_secret_here
HMAC_MAX_AGE_SECONDS=300

# Logging
RUST_LOG=info
LOG_FORMAT=json

# CORS
CORS_ALLOWED_ORIGINS=http://localhost,https://your-frontend.com
